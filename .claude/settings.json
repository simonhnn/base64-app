{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm test)",
      "Bash(npm run test:*)",
      "Bash(npm install)",
      "Bash(node --check:*)",
      "Bash(npx wrangler pages dev:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(curl:*)",
      "Read",
      "Edit",
      "Write"
    ],
    "deny": [
      "Read(./.dev.vars)",
      "Read(./.env)"
    ]
  }
}
